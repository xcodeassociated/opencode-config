{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "provider": {
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vllm",
      "options": {
        "baseURL": "{env:OPENCODE_VLLM_BASE_URL}"
      },
      "models": {
        "openai/gpt-oss-120b": {
          "name": "openai/gpt-oss-120b",
          "reasoning": true,
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "tool_call": true
        },
        "qwen/qwen3.5-122B": {
          "name": "qwen/qwen3.5-122B",
          "reasoning": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 65536
          },
          "tool_call": true
        },
        "google/gemma-4-26B-A4B-it": {
          "name": "google/gemma-4-26B-A4B-it",
          "reasoning": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 65536
          },
          "tool_call": true
        },
        "qwen/qwen3.6-27B": {
          "name": "qwen/qwen3.6-27B",
          "reasoning": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 420000,
            "input": 340000,
            "output": 65536
          },
          "tool_call": true
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "edit": "ask",
    "bash": "ask",
    "skill": {
      "*": "deny"
    },
    "task": {
      "*": "deny"
